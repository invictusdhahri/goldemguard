# Copy: cp .env.example .env

# Supabase (server-side)
SUPABASE_URL=
# Anon key: required for API routes (JWT + RLS). Get from `supabase status` or project settings.
SUPABASE_ANON_KEY=
# Service role: required for the analysis worker (bypasses RLS for jobs/results/storage download).
SUPABASE_SERVICE_ROLE_KEY=

# Auth
JWT_SECRET=

# Queue / cache
REDIS_URL=redis://localhost:6379

# SightEngine API (image + video AI-detection)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# xAI Grok (second detection signal — optional, skipped if missing)
XAI_API_KEY=

# Anthropic Claude Haiku (reasoning synthesis — optional, skipped if missing)
ANTHROPIC_API_KEY=
# Optional override (default: claude-haiku-4-5)
# ANTHROPIC_MODEL=

# Resemble AI (audio deepfake detection — also used for video audio extraction)
RESEMBLE_API_KEY=
# Seconds from the start of the file to analyze (default 5). API-only segment; full file is still uploaded.
# RESEMBLE_AUDIO_SAMPLE_SECONDS=5
# Optional override (default: https://app.resemble.ai/api/v2)
# RESEMBLE_API_BASE=

# Sapling AI (document / text AI-detection — PDF & DOCX)
# Private API key from the dashboard ("API Key"); see https://sapling.ai/docs/api/api-access/
# The "Public Key" in the UI is for browser/JavaScript SDK only — the backend uses SAPLING_API_KEY.
SAPLING_API_KEY=

# Video analysis config (optional — defaults shown)
# Maximum allowed video duration in seconds. Videos longer than this are rejected.
# VIDEO_MAX_DURATION_SECONDS=10
# Seconds of audio to extract from the start of the video for Resemble AI deepfake check.
# VIDEO_AUDIO_SAMPLE_SECONDS=5
# Override ffmpeg/ffprobe binary paths (useful in Docker if not in $PATH)
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# API server
PORT=4000
