# Copied to .env for local builds (pnpm build). Vite inlines VITE_* at compile time.
# Production builds: omit or leave empty to use https://clawy-api.onrender.com/api
VITE_API_BASE=http://localhost:4000/api
# Comma-separated origins of the GolemGuard web app (localStorage session sync). Optional; defaults include localhost:3000 and goldemguard.vercel.app.
# VITE_WEB_APP_ORIGINS=http://localhost:3000,https://goldemguard.vercel.app
