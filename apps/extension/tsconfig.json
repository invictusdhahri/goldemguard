{
  "extends": "@veritas/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": true,
    "strict": true,
    "allowImportingTsExtensions": true,
    "types": ["chrome"]
  },
  "include": ["src", "manifest.json"],
  "exclude": ["node_modules", "dist"]
}
