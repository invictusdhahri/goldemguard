{
  "manifest_version": 3,
  "name": "VeritasAI",
  "version": "0.1.0",
  "description": "Detect AI-generated media and verify claims everywhere — Twitter/X (especially), Facebook, and any website. Powered by VeritasAI.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "VeritasAI — X/Twitter, Facebook & any site",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "<all_urls>"
      ],
      "js": ["src/content/scraper.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "https://veritasai.com/*",
        "https://www.veritasai.com/*"
      ],
      "js": ["src/content/webAuthSync.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
