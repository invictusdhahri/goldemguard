# Copy: cp .env.example .env.local

# Supabase (public anon key — safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL for auth redirects (Vercel: set in Production to https://your-domain.vercel.app/)
# NEXT_PUBLIC_SITE_URL=https://goldemguard.vercel.app/

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000/api
